# Copy this file to backend/.env before running the backend.
# Never commit backend/.env because it contains real secrets.

# Required: Volcengine Ark API key.
ARK_API_KEY=your_ark_api_key_here

# Usually keep the default Ark base URL.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Default model for video analysis and structure transfer.
# Use the pro model for competition-quality runs.
ARK_MODEL=doubao-seed-2-0-pro-260215

# Optional: override video understanding sampling FPS.
# Leave empty unless you need a faster or denser test.
# VIDEO_ANALYSIS_FPS=3

# Optional: used only when pushing from scripts or deployment helpers.
GITHUB_ACCESS_TOKEN=your_github_token_here

# Optional deployment metadata for teammates who deploy the demo.
SERVER_IP=
SERVER_SSH=
DOMAIN=
